# ── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public origin used to build absolute URLs for uploaded files (resumes/avatars).
# Leave blank locally (falls back to the request host); set to the API's public
# URL in production, e.g. https://api.jobeee.com
APP_URL=

# Comma-separated list of frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:5173

# ── Database ───────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/jobeee
# Used when NODE_ENV=production
MONGODB_URI_PRO=

# ── Auth (JWT via jose) + cookie ───────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_TIME=7d
COOKIE_EXPIRES_TIME=7

# ── File uploads (resumes + avatars) ───────────────────
UPLOAD_PATH=./public/uploads
MAX_FILE_SIZE=2000000

# ── Geocoding (OpenCage) ───────────────────────────────
OPENCAGE_API_KEY=

# ── Email (nodemailer / SMTP) ──────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# "From" header (optional — defaults to "Jobeee <SMTP_USER>")
SMTP_FROM_NAME=Jobeee
SMTP_FROM_EMAIL=
